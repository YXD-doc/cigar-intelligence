# Cigar Search System Configuration
APP_NAME="Cigar Intelligence System"
VERSION="1.0.0"

# Server
HOST="0.0.0.0"
PORT=8000

# Database
DB_PATH="./database/cigar_data.json"
HISTORY_PATH="./history/search_log.json"

# Image Recognition
MODEL_NAME="efficientnet_b0"
IMAGE_SIZE=224
CONFIDENCE_THRESHOLD=0.5
TOP_K_RESULTS=5

# Search Settings
FUZZY_THRESHOLD=60
MAX_SUGGESTIONS=10

# Privacy Mode
PRIVATE_MODE=true
SESSION_TIMEOUT=3600
